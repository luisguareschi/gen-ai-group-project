# LLM backend: "ollama" (local) or "openai"
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
# Available models (pull first with `ollama pull <model>`):
#   qwen2.5:3b  qwen2.5:7b  qwen3:8b  gemma3:4b
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI settings (used when LLM_BACKEND=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Shared
LLM_TEMPERATURE=0.2

# Pipeline tuning
MAX_CLAIMS=3
MAX_ARTICLE_CHARS=2000
